# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service role key has FULL database access — bypass Row Level Security.
# Used ONLY in server-side API routes and the ingestion script. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com (no credit card required)
GROQ_API_KEY=your-groq-api-key

# Model for generation. Free options on Groq:
#   llama-3.1-8b-instant   (fast, good quality — default)
#   llama-3.3-70b-versatile (slower, higher quality)
#   gemma2-9b-it
GROQ_MODEL=llama-3.1-8b-instant

# ─── Ingestion ────────────────────────────────────────────────────────────────
# Path to the directory containing your NASA PDF files.
# Default: ./data/raw
NASA_PDF_DIR=./data/raw
