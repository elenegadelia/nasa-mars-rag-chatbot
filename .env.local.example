# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
#
# NEXT_PUBLIC_ prefix makes these available in the browser (safe — anon key only).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key has FULL database access — bypass Row Level Security.
# Used ONLY in server-side API routes and the ingestion script. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenRouter ──────────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai (no credit card required for free models)
OPENROUTER_API_KEY=your-openrouter-api-key

# Model to use for generation. Free options:
#   mistralai/mistral-7b-instruct:free
#   meta-llama/llama-3-8b-instruct:free
#   google/gemma-3-4b-it:free
# Check current free models at https://openrouter.ai/models?q=free
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ─── Ingestion ────────────────────────────────────────────────────────────────
# Path to the directory containing your NASA PDF files.
# Default: ./data  (drop PDFs in the data/ folder and leave this unset)
# Override if your PDFs are stored elsewhere, e.g. /Users/you/Desktop/Nasa
NASA_PDF_DIR=./data/raw

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
